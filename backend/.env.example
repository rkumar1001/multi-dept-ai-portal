# Application
APP_NAME=multi-dept-ai-portal
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_portal

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (LLM Provider)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limits (per minute)
RATE_LIMIT_DEFAULT=30
RATE_LIMIT_ADMIN=100
