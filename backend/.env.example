# Application
APP_NAME=multi-dept-ai-portal
APP_ENV=development
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Anthropic (LLM Provider)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limits (per minute)
RATE_LIMIT_DEFAULT=30
RATE_LIMIT_ADMIN=100

# Default Admin (seeded on startup)
DEFAULT_ADMIN_EMAIL=admin@gmail.com
DEFAULT_ADMIN_PASSWORD=admin123

# FCM Backend (Restaurant Department)
FCM_BACKEND_URL=http://your-fcm-backend-url
FCM_BACKEND_SECRET=your-fcm-backend-secret

# FleetHunt (Logistics Department)
FLEETHUNT_BASE_URL=https://app.fleethunt.ca/api
FLEETHUNT_API_KEY=your-fleethunt-api-key

# Google OAuth (Gmail Integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/email/callback/gmail

# Microsoft OAuth (Outlook Integration)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/email/callback/outlook
MICROSOFT_TENANT_ID=common
